# ============================================================
# WORLDCUP PREDICTOR — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it's already in .gitignore
# ============================================================

# --- SUPABASE ---
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- FOOTBALL API ---
# Sign up free at: https://www.football-data.org/
# Free tier gives you access to major competitions including World Cup
FOOTBALL_API_KEY=your-football-data-org-api-key-here

# Which competition to track. Examples:
#   WC   = FIFA World Cup
#   EC   = European Championship
#   PL   = English Premier League
#   CL   = Champions League
# Full list: https://www.football-data.org/coverage
FOOTBALL_COMPETITION_CODE=WC

# --- CRON JOB SECRET ---
# Make up a random long string — used to protect the cron endpoint
# Example: openssl rand -hex 32
CRON_SECRET=make-up-a-long-random-secret-string-here

# --- NEXT PUBLIC APP URL ---
# In development this is localhost. In production, your Vercel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
